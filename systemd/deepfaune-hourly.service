[Unit]
Description=DeepFaune New England hourly wildlife pipeline
After=network-online.target remote-fs.target
Wants=network-online.target remote-fs.target

[Service]
Type=oneshot
WorkingDirectory=%h/deepfaune_new_england
ExecStart=%h/deepfaune_new_england/.venv/bin/python %h/deepfaune_new_england/run_pipeline.py --hourly

[Install]
WantedBy=multi-user.target
